#include <stdio.h>
#include <stdlib.h>

int main() {
    FILE *f, *g;
    char ch;
    long size;

    f = fopen("f.txt", "r");
    if (f == NULL) {
        printf("Ошибка открытия файла f.txt\n");
        return 1;
    }

    g = fopen("g.txt", "w");
    if (g == NULL) {
        printf("Ошибка создания файла g.txt\n");
        fclose(f);
        return 1;
    }

    fseek(f, 0, SEEK_END);
    size = ftell(f);
    
    for (long i = size - 1; i >= 0; i--) {
        fseek(f, i, SEEK_SET);
        ch = fgetc(f);
        fputc(ch, g);
    }

    fclose(f);
    fclose(g);
    
    printf("Файл g.txt создан с содержимым f.txt в обратном порядке\n");
    
    return 0;
}
